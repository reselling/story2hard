# Storyteller server
# If running on the same host, you can also use http://localhost:<port>
STORYTELLER_URL=https://your-server.ts.net
STORYTELLER_USERNAME=your_username
STORYTELLER_PASSWORD=your_password

# Hardcover — get your token at https://hardcover.app/account/api
# Paste only the token, without the "Bearer " prefix
HARDCOVER_TOKEN=your_hardcover_token

# Optional tuning (defaults shown)
SYNC_INTERVAL_MINUTES=15
MIN_PROGRESS_DELTA=0.01
